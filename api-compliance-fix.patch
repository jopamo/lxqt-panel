# API/ABI Compliance Fix for LXQt Panel Fork
# This patch brings the forked lxqt-panel into full API/ABI compliance
# after removing Wayland + globalkeys support, without reintroducing them.

# Changes:
# 1. Fixed screenName() to return empty QString (API compliance)
# 2. Removed references to deleted member variables: mWAnimation, mLayerWindow
# 3. Maintains binary compatibility with liblxqt's ILXQtPanel interface

--- a/panel/lxqtpanel.h
+++ b/panel/lxqtpanel.h
@@ -147,7 +147,7 @@ class LXQT_PANEL_API LXQtPanel : public QFrame, public ILXQtPanel {
   void willShowWindow(QWidget* w) override;
   void pluginFlagsChanged(const ILXQtPanelPlugin* plugin) override;
   bool isLocked() const override { return mLockPanel; }
-  QString screenName() const override { return mScreenName; }
+  QString screenName() const override { return QString(); }
   // ........ end of ILXQtPanel overrides

   /**

